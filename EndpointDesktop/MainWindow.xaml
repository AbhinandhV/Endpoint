<Window x:Class="EndpointDesktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Endpoint Control Panel" 
        Height="800" Width="1200"
        MinHeight="600" MinWidth="900"
        Background="{StaticResource BgPrimary}"
        WindowStartupLocation="CenterScreen">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource BgSecondary}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo and Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="⚙" FontSize="24" Foreground="{StaticResource Accent}" Margin="0,0,10,0"/>
                    <TextBlock Text="Endpoint Control Panel" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                </StackPanel>

                <!-- Machine Info -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="💻" FontSize="14" Margin="0,0,8,0"/>
                    <TextBlock x:Name="MachineNameText" Text="Loading..." Foreground="{StaticResource TextSecondary}" FontSize="13"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="350"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel - Actions -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="20">
                <StackPanel x:Name="ActionsPanel">
                    <!-- Categories will be added dynamically -->
                </StackPanel>
            </ScrollViewer>

            <!-- Right Panel - Output & History -->
            <Grid Grid.Column="1" Background="{StaticResource BgSecondary}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Output Panel -->
                <Border Grid.Row="0" Margin="16" Style="{StaticResource Card}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="📋" FontSize="14" Margin="0,0,8,0"/>
                            <TextBlock Text="Output" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                        </StackPanel>

                        <Border Grid.Row="1" Background="{StaticResource BgPrimary}" CornerRadius="8" Padding="12">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <TextBox x:Name="OutputText" 
                                         IsReadOnly="True" 
                                         TextWrapping="Wrap"
                                         Background="Transparent"
                                         Foreground="{StaticResource TextSecondary}"
                                         BorderThickness="0"
                                         FontFamily="Consolas"
                                         FontSize="12"
                                         Text="Ready to execute actions..."/>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Border>

                <!-- History Panel -->
                <Border Grid.Row="1" Margin="16,0,16,16" Style="{StaticResource Card}" MaxHeight="250">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="📜" FontSize="14" Margin="0,0,8,0"/>
                            <TextBlock Text="History" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                            <Button Content="Clear" Margin="12,0,0,0" Padding="8,4" FontSize="11" 
                                    Background="Transparent" Foreground="{StaticResource TextMuted}" 
                                    BorderThickness="0" Cursor="Hand" Click="ClearHistory_Click"/>
                        </StackPanel>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="HistoryList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource BgSecondary}" CornerRadius="6" Padding="10" Margin="0,0,0,6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding ActionName}" Foreground="{StaticResource TextPrimary}" FontSize="12" FontWeight="Medium"/>
                                                    <TextBlock Text="{Binding TimeAgo}" Foreground="{StaticResource TextMuted}" FontSize="10" Margin="0,2,0,0"/>
                                                </StackPanel>
                                                <Border Grid.Column="1" CornerRadius="4" Padding="6,2" VerticalAlignment="Center"
                                                        Background="{Binding StatusColor}">
                                                    <TextBlock Text="{Binding Status}" Foreground="White" FontSize="10" FontWeight="SemiBold"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
